# ─────────────────────────────────────────────────────────────────────────────
# SESSION STATE — initialise pipeline once per session
# ─────────────────────────────────────────────────────────────────────────────

@st.cache_resource(show_spinner=False)
def init_pipeline() -> MedicalRAGPipeline:
    """Build the RAG pipeline and index the knowledge base (runs once)."""
    pipeline = MedicalRAGPipeline(
        data_path="data/medical_data.txt",
        top_k=3,
    )
    pipeline.build_index()
    return pipeline


# ─────────────────────────────────────────────────────────────────────────────
# SIDEBAR
# ─────────────────────────────────────────────────────────────────────────────

with st.sidebar:
    st.markdown("### ⚙️ Configuration")

    show_sources = st.toggle("Show retrieved source chunks", value=True)
    top_k = st.slider("Chunks to retrieve (top-k)", 1, 5, 3)

    st.markdown("---")
    st.markdown("### 🗂️ Knowledge Base")

    # Try to initialise and show status
    try:
        pipeline = init_pipeline()
        pipeline.top_k = top_k   # update dynamically from slider
        chunk_count = pipeline.db.count()
        st.markdown(
            f'<p class="status-ok">✅ {chunk_count} chunks indexed in Endee</p>',
            unsafe_allow_html=True,
        )
    except Exception as e:
        st.markdown(
            f'<p class="status-warn">⚠️ Pipeline error: {e}</p>',
            unsafe_allow_html=True,
        )
        pipeline = None

    st.markdown("---")
    st.markdown("### 📌 Sample Questions")
    sample_questions = [
        "What are the symptoms of diabetes?",
        "How is asthma treated?",
        "What causes high blood pressure?",
        "What are migraine symptoms?",
        "How to treat UTI?",
    ]
    for q in sample_questions:
        if st.button(q, key=q):
            st.session_state["prefill_query"] = q

    st.markdown("---")
    st.markdown(
        "<small style='color:#aaa'>Built with Python · Streamlit · Endee · Claude</small>",
        unsafe_allow_html=True,
    )


# ─────────────────────────────────────────────────────────────────────────────
# MAIN PAGE
# ─────────────────────────────────────────────────────────────────────────────

# Hero header
st.markdown(
    """
    <div class="hero-header">
        <div class="hero-title">🩺 AI Medical Assistant</div>
        <div class="hero-subtitle">
            RAG-powered answers retrieved from a curated medical knowledge base via Endee
        </div>
    </div>
    """,
    unsafe_allow_html=True,
)

# Pre-fill query from sidebar sample click
default_query = st.session_state.pop("prefill_query", "")

# ── Question input ────────────────────────────────────────────────────────────
query = st.text_area(
    label="Your medical question",
    value=default_query,
    placeholder="e.g.  What are the symptoms of hypothyroidism?",
    height=100,
    label_visibility="collapsed",
)

ask_button = st.button("🔍  Get Answer")

# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE EXECUTION
# ─────────────────────────────────────────────────────────────────────────────

if ask_button:
    if not query.strip():
        st.warning("Please enter a question before clicking Get Answer.")
    elif pipeline is None:
        st.error("Pipeline failed to initialise. Check the sidebar for details.")
    else:
        with st.spinner("Searching knowledge base and generating answer…"):
            try:
                answer, retrieved_chunks = pipeline.ask(query.strip())
            except Exception as e:
                st.error(f"Something went wrong: {e}")
                st.stop()

        # ── Answer card ───────────────────────────────────────────────────────
        st.markdown(
            f"""
            <div class="answer-card">
                <div class="card-title">🤖 AI Answer</div>
                <div class="answer-text">{answer.replace(chr(10), '<br>')}</div>
            </div>
            """,
            unsafe_allow_html=True,
        )

        # ── Source chunks (optional) ──────────────────────────────────────────
        if show_sources and retrieved_chunks:
            st.markdown(
                '<div class="card"><div class="card-title">📚 Retrieved Sources from Endee</div>',
                unsafe_allow_html=True,
            )

            # Show top 2 sources (as required), rest collapsed
            display_chunks = retrieved_chunks[:2]

            for i, chunk in enumerate(display_chunks, 1):
                # Trim very long chunks for display
                preview = chunk["text"][:500] + ("…" if len(chunk["text"]) > 500 else "")
                st.markdown(
                    f"""
                    <div class="source-card">
                        <span class="score-badge">Source {i} &nbsp;·&nbsp; similarity {chunk['score']:.3f}</span><br>
                        {preview}
                    </div>
                    """,
                    unsafe_allow_html=True,
                )

            if len(retrieved_chunks) > 2:
                with st.expander(f"Show {len(retrieved_chunks) - 2} more source(s)"):
                    for i, chunk in enumerate(retrieved_chunks[2:], 3):
                        preview = chunk["text"][:400] + ("…" if len(chunk["text"]) > 400 else "")
                        st.markdown(
                            f"""
                            <div class="source-card">
                                <span class="score-badge">Source {i} &nbsp;·&nbsp; similarity {chunk['score']:.3f}</span><br>
                                {preview}
                            </div>
                            """,
                            unsafe_allow_html=True,
                        )

            st.markdown("</div>", unsafe_allow_html=True)

